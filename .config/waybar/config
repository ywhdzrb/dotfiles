{
  "layer": "top",
  "position": "top",
  "height": 28,
  "spacing": 0,
  "modules-left": ["hyprland/workspaces"],
  "modules-center": ["custom/nowplaying"],
  "modules-right": [
    "cava",
    "network",
    "network#speed",
    "cpu",
    "memory",
    "disk",
    "custom/gpu",
    "custom/temp",
    "pulseaudio",
    "battery",
    "clock",
    "tray"
  ],

  "hyprland/workspaces": {
    "format": "{icon}",
    "format-icons": {
      "1": "дёҖ",
      "2": "дәҢ",
      "3": "дёү",
      "4": "еӣӣ",
      "5": "дә”",
      "6": "е…ӯ",
      "7": "дёғ",
      "8": "е…«",
      "9": "д№қ"
    },
    "all-outputs": true,
    "persistent-workspaces": {
      "*": 9
    }
  },

  "hyprland/window": {
    "max-length": 50,
    "separate-outputs": true
  },

  "cpu": {
    "interval": 1,
    "format": "пӢӣ {usage}%",
    "tooltip": true,
    "on-click": "kitty --class=htop htop",
    "min-length": 5,
    "width": 5,
    "align": "center"
  },

  "memory": {
    "interval": 5,
    "format": "пғү {percentage}%",
    "tooltip-format": "еҶ…еӯҳдҪҝз”Ё: {used:0.1f}G/{total:0.1f}G",
    "min-length": 5,
    "width": 5,
    "align": "center"
  },

  "disk": {
    "interval": 30,
    "path": "/",
    "format": "пӮ  {percentage_used}%",
    "tooltip-format": "и·Ҝеҫ„: {path}\nе·Із”Ё: {used}\nеҸҜз”Ё: {free}\nжҖ»и®Ў: {total}",
    "on-click": "dolphin",
    "min-length": 5,
    "width": 5,
    "align": "center"
  },

  "network": {
    "interval": 5,
    "format-icons": ["у°ӨҜ", "у°Өҹ", "у°Өў", "у°ӨҘ", "у°ӨЁ"],
    "format-ethernet": "пғҒ {ifname} ({ipaddr})",
    "format-wifi": "пҮ« {essid} ({signalStrength}%)",
    "format-disconnected": "у°Ө® ж–ӯејҖиҝһжҺҘ",
    "tooltip-format": "пғҒ {ifname} via {gwaddr}",
    "on-click": "exec setsid uwsm app -- 'kitty' --class=Impala -e impala",
    "on-click-right": "/home/ywhdzrb/.config/waybar/scripts/network_popup.py"
  },

  "network#speed": {
    "interval": 1,
    "format": "пҖҷ {bandwidthDownBytes} пӮ“ {bandwidthUpBytes}",
    "format-alt": "пҖҷ {bandwidthDownBytes} пӮ“ {bandwidthUpBytes}",
    "min-length": 22,
    "width": 22,
    "align": "center",
    "tooltip-format": "дёӢиҪҪ: {bandwidthDownBytes}\nдёҠдј : {bandwidthUpBytes}"
  },

  "custom/gpu": {
    "exec": "/home/ywhdzrb/.config/waybar/scripts/gpu.sh",
    "return-type": "text",
    "interval": 2,
    "min-length": 5,
    "width": 5,
    "align": "center",
    "on-click": "kitty --class=nvtop nvtop"
  },

  "custom/temp": {
    "exec": "/home/ywhdzrb/.config/waybar/scripts/temp.sh",
    "return-type": "json",
    "interval": 5,
    "min-length": 5,
    "width": 5,
    "align": "center"
  },

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-bluetooth": "{icon}пҠ” {volume}%",
    "format-muted": "у°–Ғ йқҷйҹі",
    "format-icons": {
      "headphone": "у°ӢӢ",
      "hands-free": "пҖҘ",
      "headset": "у°ӢҺ",
      "phone": "пӮ•",
      "portable": "пӮ•",
      "car": "пҶ№",
      "default": ["у°•ҝ", "у°–Җ", "у°•ҫ"]
    },
    "scroll-step": 5,
    "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
    "on-click-right": "pavucontrol",
    "tooltip": false,
    "min-length": 5,
    "width": 5,
    "align": "center"
  },

  "battery": {
    "interval": 10,
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": "пҮҰ {capacity}%",
    "format-plugged": "пҮҰ {capacity}%",
    "format-alt": "{icon} {time}",
    "format-icons": ["у°ӮҺ", "у°Ғә", "у°Ғ»", "у°Ғј", "у°ҒҪ", "у°Ғҫ", "у°Ғҝ", "у°ӮҖ", "у°ӮҒ", "у°ӮӮ", "у°Ғ№"],
    "tooltip-format": "{capacity}% еү©дҪҷ"
  },

  "clock": {
    "interval": 1,
    "format": "{:%Y-%m-%d %H:%M:%S}",
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "actions": {
      "on-click-right": "mode",
      "on-click-forward": "tz_up",
      "on-click-backward": "tz_down"
    }
  },

  "tray": {
    "icon-size": 16,
    "spacing": 8
  },

  "cava": {
    "cava_config": "/home/ywhdzrb/.config/waybar/cava-raw.conf",
    "input_delay": 2,
    "format-icons": ["в–Ғ", "в–Ӯ", "в–ғ", "в–„", "в–…", "в–Ҷ", "в–Ү", "в–Ҳ"]
  },

  "custom/nowplaying": {
    "exec": "/home/ywhdzrb/.config/waybar/scripts/nowplaying.sh",
    "exec-rem": true,
    "return-type": "text",
    "escape": true,
    "max-length": 120,
    "on-click-right": "/home/ywhdzrb/.config/waybar/scripts/music_popup.py"
  }
}
